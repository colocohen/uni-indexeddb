{
  "name": "uni-indexeddb",
  "version": "1.1.0",
  "description": "Unified key-value storage for browser and server. IndexedDB in the browser, LevelDB on the server. Same API everywhere.",
  "main": "index.js",
  "module": "index.mjs",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./index.mjs",
      "require": "./index.js",
      "types": "./index.d.ts"
    }
  },
  "browser": {
    "./src/engine-leveldb.js": "./src/engine-indexeddb.js"
  },
  "keywords": [
    "indexeddb",
    "leveldb",
    "unified",
    "key-value",
    "kv",
    "storage",
    "database",
    "binary",
    "universal",
    "service-worker"
  ],
  "author": "colocohen",
  "license": "MIT",
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "src/",
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/colocohen/uni-indexeddb.git"
  },
  "homepage": "https://github.com/colocohen/uni-indexeddb#readme",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/colocohen"
    }
  ],
  "optionalDependencies": {
    "classic-level": "^2.0.0"
  }
}
